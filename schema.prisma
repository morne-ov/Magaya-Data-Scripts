model Allocation {
  id           String     @id @default(cuid())
  siteId       String?
  site         Site?      @relation(fields: [siteId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  /** Bucket start instant for UI grouping (not unique). */
  startsAt     DateTime
  /** Bucket end instant for UI grouping (not unique). */
  endsAt       DateTime

  status       AllocationPlanStatus @default(DRAFT)
  finalizedAt  DateTime?
  finalizedById String?
  finalizedBy  User?      @relation("AllocationFinalizedBy", fields: [finalizedById], references: [id])

  totalLoadCount       Int      @default(0)
  totalTonnage         Float    @default(0)
  weightedGrade        Float?
  totalEvaluatedAmount Float    @default(0)

  /** When created/last modified (draft) for audit; set on finalize too. */
  allocatedAt  DateTime
  allocatedById String?
  allocatedBy  User?      @relation("AllocationAllocatedBy", fields: [allocatedById], references: [id])

  pdfUrl       String?
  note         String?

  weighbridges Weighbridge[]
  stockpiles   Stockpile[]
  stockpileAllocationEvents StockpileAllocationEvent[]
  allocationStockpiles AllocationStockpile[]
  allocationStockpileLoads AllocationStockpileLoad[]
  allocationStockpileBatches AllocationStockpileBatch[]
  allocationWeighbridges AllocationWeighbridge[]

  @@unique([siteId, startsAt, endsAt])
  @@index([siteId, startsAt])
  @@index([siteId, startsAt, endsAt])
  @@index([siteId, allocatedAt])
}

enum AllocationPlanStatus {
  DRAFT
  FINALIZED
}

model AllocationStockpile {
  id           String    @id @default(cuid())
  siteId       String?
  site         Site?     @relation(fields: [siteId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  allocationId String
  allocation   Allocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)

  stockpileId  String
  stockpile    Stockpile  @relation(fields: [stockpileId], references: [id], onDelete: Cascade)

  addedAt      DateTime  @default(now())
  addedById    String?
  addedBy      User?     @relation("AllocationStockpileAddedBy", fields: [addedById], references: [id])

  removedAt    DateTime?

  @@unique([allocationId, stockpileId])
  @@index([allocationId, removedAt])
}

/**
 * Snapshot of which loads (weighbridges) from a stockpile were allocated in a given allocation.
 * This decouples allocation reports/totals from the live stockpile membership.
 */
model AllocationStockpileLoad {
  id            String     @id @default(cuid())
  siteId        String?
  site          Site?      @relation(fields: [siteId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  allocationId  String
  allocation    Allocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)

  stockpileId   String
  stockpile     Stockpile  @relation(fields: [stockpileId], references: [id], onDelete: Cascade)

  weighbridgeId String
  weighbridge   Weighbridge @relation(fields: [weighbridgeId], references: [id], onDelete: Cascade)

  removedAt     DateTime?

  @@unique([allocationId, stockpileId, weighbridgeId])
  @@index([allocationId, removedAt])
  @@index([stockpileId, removedAt])
}

model AllocationStockpileBatch {
  id           String    @id @default(cuid())
  siteId       String?
  site         Site?     @relation(fields: [siteId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  allocationId String
  allocation   Allocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)

  stockpileId  String
  stockpile    Stockpile  @relation(fields: [stockpileId], references: [id], onDelete: Cascade)

  addedById    String?
  addedBy      User?     @relation("AllocationStockpileBatchAddedBy", fields: [addedById], references: [id])

  removedAt    DateTime?

  loads        AllocationStockpileBatchLoad[]

  @@index([allocationId, removedAt])
  @@index([stockpileId, removedAt])
}

model AllocationStockpileBatchLoad {
  id            String    @id @default(cuid())
  siteId        String?
  site          Site?     @relation(fields: [siteId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  batchId       String
  batch         AllocationStockpileBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  weighbridgeId String
  weighbridge   Weighbridge @relation(fields: [weighbridgeId], references: [id], onDelete: Cascade)

  removedAt     DateTime?

  @@unique([batchId, weighbridgeId])
  @@index([batchId, removedAt])
}

/// Direct allocation of individual loads (not via a stockpile). Mirrors AllocationStockpile soft-remove.
model AllocationWeighbridge {
