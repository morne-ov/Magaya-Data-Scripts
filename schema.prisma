  calculatedAU             Float?
  auSource                 WeighbridgeAuSource?
  onTheGround              OnTheGround?
  paymentReportCalculation PaymentReportCalculation?
  paymentReport            PaymentReport?            @relation(fields: [paymentReportId], references: [id])
