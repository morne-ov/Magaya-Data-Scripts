  addedAt       DateTime  @default(now())
  addedById     String?
  addedBy       User?     @relation("AllocationWeighbridgeAddedBy", fields: [addedById], references: [id])

  removedAt     DateTime?

  @@unique([allocationId, weighbridgeId])
  @@index([allocationId, removedAt])
}

