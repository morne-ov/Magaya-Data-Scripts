generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

generator typescriptInterfaces {
  provider          = "prisma-generator-typescript-interfaces"
  output            = "./typescript-interfaces.ts"
  geometryInterface = "./geometry.d.ts"
  previewFeatures   = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, citext]
}

model globalSettings {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  field       String   @unique
  value       String?
  description String?
}

model EmailAuditLog {
  id           String              @id @default(cuid())
  siteId       String?
  site         Site?               @relation(fields: [siteId], references: [id])
  emailType    String
  recipient    String
  subject      String
  body         String
  status       EmailAuditLogStatus
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  errorMessage String?
  messageId    String?
}

enum EmailAuditLogStatus {
  SENT
  FAILED
  PENDING
}

model AuditLog {
  id                 String              @id @default(cuid())
  siteId             String?
  site               Site?               @relation(fields: [siteId], references: [id])
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  userId             String
  method             AuditLogMethod
  auditRecordDetails AuditRecordDetail[]
}

enum AuditLogMethod {
  GET
  POST
  PUT
  DELETE
}

model AuditRecordDetail {
  id             String   @id @default(cuid())
  siteId         String?
  site           Site?    @relation(fields: [siteId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  auditLogId     String
  auditLog       AuditLog @relation(fields: [auditLogId], references: [id])
  recordId       String
  requestPayload Json
}

enum SubAreaOperationType {
  DUMP
  EXTERNAL
  INTERNAL
  JV
  CLAIM
  MINING
}

model SubArea {
  id                        String                                 @id @default(cuid())
  siteId                    String?
  site                      Site?                                  @relation("SubAreaPrimarySite", fields: [siteId], references: [id])
  name                      String                                 @db.Citext
  operationType             SubAreaOperationType?
  sites                     Site[]
  geometry                  Unsupported("geometry(Polygon,4326)")? @map("geometry") /// @type: Geometry
  createdAt                 DateTime                               @default(now())
  updatedAt                 DateTime                               @updatedAt
  cluster                   Cluster?                               @relation(fields: [clusterId], references: [id])
  clusterId                 String?
  workOrders                WorkOrder[]
  weighbridges              Weighbridge[]
  areaTransportCosts        AreaTransportCosts[]
  areaRoyaltyConfigurations AreaRoyaltyConfiguration[]
  samples                   Sample[]
  jobs                      Job[]

  @@unique([siteId, name])
  @@index([name])
}

model Plan {
  id              String           @id @default(cuid())
  siteId          String?
  site            Site?            @relation(fields: [siteId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  date            DateTime
  planAssignments PlanAssignment[]
}

model PlanAssignment {
  id          String     @id @default(cuid())
  siteId      String?
  site        Site?      @relation(fields: [siteId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  plan        Plan       @relation(fields: [planId], references: [id])
  planId      String
  jobs        Job[]
  equipment   Equipment? @relation(fields: [equipmentId], references: [id])
  equipmentId String?
}

model HistoricData {
  id                          String               @id @default(cuid())
  siteId                      String?
  site                        Site?                @relation(fields: [siteId], references: [id])
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  client_clientId             String?
  weighbridge_createdAt       DateTime
  weighbridge_loadCode        String
  weighbridge_operationType   OperationType?
  transportCompany            String
  weighbridge_area            String
  onTheGround_sandOreType     SandOreType
  client_name                 String
  weighbridge_tonnage         Float
  onTheGround_dryTonnage      Float
  onTheGround_cleanTonnage    Float
  onTheGround_debrisFactor    Float
  stockValue_transportCost    Float
  stockValue_paidAverageGrade Float
  stockValue_grossPayment     Float
  evaluated                   Float
  stockValue_stockStatus      StockStatus
  weighbridge_primer          WeighbridgePrimer?
  weighbridge_prefix          String
  subArea_cluster             String
  sustainabilityStatus        SustainabilityStatus
}

model Client {
  id               String          @id @default(cuid())
  siteId           String?
  site             Site?           @relation(fields: [siteId], references: [id])
  firstName        String          @db.Citext
  middleName       String?
  lastName         String          @db.Citext
  idNumber         String?
  address          String?
  contactNumber    String[]
  whatsapp         String[]
  createdBy        User?           @relation(fields: [createdById], references: [id])
  createdById      String?
  potentialClient  Boolean         @default(false)
  email            String[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  shafts           Shaft[]
  syndicates       Syndicate[]
  jobs             Job[]
  status           ClientStatus    @default(ACTIVE)
  workOrders       WorkOrder[]
  artisanalMinerId String?
  samples          Sample[]
  weighbridges     Weighbridge[]
  abc              String?
  clientId         String?
  paymentReports   PaymentReport[]
  freeTransport    FreeTransport[]

  @@unique([siteId, idNumber])
  @@unique([siteId, artisanalMinerId])
}

model Cluster {
  id        String                                 @id @default(cuid())
  siteId    String?
  site      Site?                                  @relation(fields: [siteId], references: [id])
  name      String                                 @db.Citext
  geometry  Unsupported("geometry(Polygon,4326)")? @map("geometry") /// @type: Geometry
  createdAt DateTime                               @default(now())
  updatedAt DateTime                               @updatedAt
  subAreas  SubArea[]
  jobs      Job[]

  @@unique([siteId, name])
  @@index([name])
}

model Exception {
  id          String    @id @default(cuid())
  siteId      String?
  site        Site?     @relation(fields: [siteId], references: [id])
  execution   Execution @relation(fields: [executionId], references: [id])
  executionId String
  description String
  evidence    Json // Array of file paths/URLs
  actionTaken String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Execution {
  id          String          @id @default(cuid())
  siteId      String?
  site        Site?           @relation(fields: [siteId], references: [id])
  procedure   Procedure       @relation(fields: [procedureId], references: [id])
  procedureId String
  user        User            @relation(fields: [userId], references: [id])
  userId      String
  responses   Json // Stores answers for each question
  status      ExecutionStatus @default(IN_PROGRESS)
  startTime   DateTime        @default(now())
  endTime     DateTime?
  exceptions  Exception[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Loadbay {
  id               String         @id @default(cuid())
  siteId           String?
  site             Site?          @relation(fields: [siteId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  name             String         @db.Citext
  description      String?
  maxTonnage       Float?
  maxNumberOfLoads Int?
  status           LoadbayStatus? @default(AVAILABLE)
  dateAllocated    DateTime?
  weighbridges     Weighbridge[]

  @@unique([siteId, name])
  @@index([name])
}

enum LoadbayStatus {
  AVAILABLE
  IN_USE
  UNAVAILABLE
  INACTIVE
}

model Job {
  id                                String             @id @default(cuid())
  siteId                            String?
  site                              Site?              @relation(fields: [siteId], references: [id])
  createdAt                         DateTime           @default(now())
  updatedAt                         DateTime           @updatedAt
  jobNumber                         String             @unique // Auto-generated: JOB-YYYY-NNNN
  jobCreationDate                   DateTime // Set from createdAt on create; used for year in jobNumber
  executionDate                     DateTime? // User-entered date when the job is to be executed
  jobCategory                       JobCategory?
  projectNumber                     String?
  department                        JobDepartment?
  estimatedJobTimeHours             Int?
  estimatedTonnage                  Int?
  client                            Client?            @relation(fields: [clientId], references: [id])
  clientId                          String?
  description                       String?
  area                              SubArea?           @relation(fields: [areaId], references: [id])
  areaId                            String?
  jobType                           JobType?
  status                            JobStatus?         @default(PENDING)
  notes                             String?
  orderNumber                       Int? // The sequence of the job in a plan assignment
  planAssignment                    PlanAssignment?    @relation(fields: [planAssignmentId], references: [id])
  planAssignmentId                  String?
  weighbridge                       Weighbridge?
  requester                         User?              @relation(fields: [requesterId], references: [id], name: "Requester")
  requesterId                       String?
  jobMaterialType                   JobMaterialType?
  jobMaterialTypeOtherSpecification String?
  jobCollectionType                 JobCollectionType?
  cluster                           Cluster?           @relation(fields: [clusterId], references: [id])
  clusterId                         String?
}

enum JobCollectionType {
  OWN_CLAIM
  JV
  BUYING
  EXPLORATION
  AFTER_MILLING
}

enum JobMaterialType {
  SANDS
  ORES
  DUMP
  GROUND_SCOOP
  AFTER_MILLING
  OTHER
}

enum JobCategory {
  INTERNAL
  EXTERNAL
}

enum JobDepartment {
  CIP
  ELUTION
  LAB
  GROUND
  ROUND_MILLS
  BALL_MILLS
  SAMPLE_RECEIVING
  CRUSHING
  SUPPLY
  STORES
}

model JobAttachment {
  id        String   @id @default(cuid())
  siteId    String?
  site      Site?    @relation(fields: [siteId], references: [id])
  // job       Job      @relation(fields: [jobId], references: [id]) Add this back if we need it otherwise delete table
  // jobId     String
  fileUrl   String // URL to the stored file
  fileType  String // MIME type or file extension
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobComment {
  id        String   @id @default(cuid())
  siteId    String?
  site      Site?    @relation(fields: [siteId], references: [id])
  // job       Job      @relation(fields: [jobId], references: [id]) Add this back if we need it otherwise delete table
  // jobId     String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Maintenance {
  id          String    @id @default(cuid())
  siteId      String?
  site        Site?     @relation(fields: [siteId], references: [id])
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  equipmentId String
  description String
  startDate   DateTime
  endDate     DateTime?
  status      String // e.g., scheduled, in-progress, completed
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Procedure {
  id          String        @id @default(cuid())
  siteId      String?
  site        Site?         @relation(fields: [siteId], references: [id])
  name        String        @db.Citext
  description String
  type        ProcedureType
  questions   Question[]
  executions  Execution[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([siteId, name])
}

model Question {
  id          String       @id @default(cuid())
  siteId      String?
  site        Site?        @relation(fields: [siteId], references: [id])
  procedure   Procedure    @relation(fields: [procedureId], references: [id])
  procedureId String
  text        String
  answerType  AnswerType
  choices     Json? // For CHOICE type questions
  order       Int // To maintain question sequence
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  imageUrl    String?
  type        QuestionType
}

model Session {
  id        String   @id @default(cuid())
  siteId    String?
  site      Site?    @relation(fields: [siteId], references: [id])
  userId    String
  token     String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])

  @@unique([siteId, token])
}

model Shaft {
  id         String                               @id @default(cuid())
  name       String                               @db.Citext
  geometry   Unsupported("geometry(Point,4326)")? @map("geometry") /// @type: Geometry
  createdAt  DateTime                             @default(now())
  updatedAt  DateTime                             @updatedAt
  client     Client?                              @relation(fields: [clientId], references: [id])
  clientId   String?
  site       Site?                                @relation(fields: [siteId], references: [id])
  siteId     String?
  workOrders WorkOrder[]

  @@unique([siteId, name])
  @@index([name])
}

model Syndicate {
  id        String   @id @default(cuid())
  siteId    String?
  site      Site?    @relation(fields: [siteId], references: [id])
  name      String   @db.Citext
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clients   Client[]

  @@unique([siteId, name])
  @@index([name])
}

model Site {
  id                                String                                 @id @default(cuid())
  siteId                            String?
  name                              String                                 @unique @db.Citext
  address                           String?
  geometry                          Unsupported("geometry(Polygon,4326)")? @map("geometry") /// @type: Geometry
  createdAt                         DateTime                               @default(now())
  updatedAt                         DateTime                               @updatedAt
  subAreas                          SubArea[]
  primarySubAreas                   SubArea[]                              @relation("SubAreaPrimarySite")
  shafts                            Shaft[]
  siteExtractionEfficiencies        SiteExtractionEfficiency[]
  emailAuditLogs                    EmailAuditLog[]
  auditLogs                         AuditLog[]
  auditRecordDetails                AuditRecordDetail[]
  plans                             Plan[]
  planAssignments                   PlanAssignment[]
  historicData                      HistoricData[]
  clients                           Client[]
  clusters                          Cluster[]
  exceptions                        Exception[]
  executions                        Execution[]
  loadbays                          Loadbay[]
  jobs                              Job[]
  jobAttachments                    JobAttachment[]
  jobComments                       JobComment[]
  maintenances                      Maintenance[]
  procedures                        Procedure[]
  questions                         Question[]
  sessions                          Session[]
  syndicates                        Syndicate[]
  telematics                        Telematics[]
  users                             User[]
  userRoles                         UserRole[]
  userPermissions                   UserPermission[]
  equipment                         Equipment[]
  equipmentCompanies                EquipmentCompany[]
  equipmentCompanyReferences        EquipmentCompanyReference[]
  equipmentCompanyMembers           EquipmentCompanyMember[]
  equipmentCompanySeniorManagements EquipmentCompanySeniorManagement[]
  equipmentCompanyTransporters      EquipmentCompanyTransporter[]
  equipmentCompanyBankingDetails    EquipmentCompanyBankingDetail[]
  verificationCodes                 VerificationCode[]
  companies                         Company[]
  fleets                            Fleet[]
  onTheGrounds                      OnTheGround[]
  areaTransportCosts                AreaTransportCosts[]
  freeTransports                    FreeTransport[]
  gradePricings                     GradePricing[]
  transportPricings                 TransportPricing[]
  areaRoyaltyConfigurations         AreaRoyaltyConfiguration[]
  manualDeductions                  ManualDeduction[]
  stockValues                       StockValue[]
  paymentReports                    PaymentReport[]
  reports                           Report[]
  budgetReports                     BudgetReport[]
  budgetReportLoads                 BudgetReportLoad[]
  paymentReportConfigurations       PaymentReportConfiguration[]
  paymentReportCalculations         PaymentReportCalculation[]
  paymentReportGeneratedGrades      PaymentReportGeneratedGrade[]
  internalEvaluations               InternalEvaluation[]
  weighbridges                      Weighbridge[]
  weighbridgeBatches                WeighbridgeBatch[]
  batches                           Batch[]
  prefixes                          Prefix[]
  samples                           Sample[]
  subSamples                        SubSample[]
  workOrders                        WorkOrder[]
  workOrderAttachments              WorkOrderAttachment[]
  workOrderComments                 WorkOrderComment[]
  bottleRollers                     BottleRoller[]
  bottleRollerGroups                BottleRollerGroup[]
  millingReceipts                   MillingReceipt[]
  crushingLoads                     CrushingLoad[]
  syncRuns                          SyncRun[]
  allocations                       Allocation[]
  allocationStockpiles              AllocationStockpile[]
  allocationStockpileLoads          AllocationStockpileLoad[]
  allocationStockpileBatches        AllocationStockpileBatch[]
  allocationStockpileBatchLoads     AllocationStockpileBatchLoad[]
  allocationWeighbridges            AllocationWeighbridge[]
  stockpileAllocationEvents         StockpileAllocationEvent[]
  @@index([name])
}

model Telematics {
  id                  String    @id @default(cuid())
  siteId              String?
  site                Site?     @relation(fields: [siteId], references: [id])
  equipment           Equipment @relation(fields: [equipmentId], references: [id])
  equipmentId         String    @unique
  telematicsId        String // TSC vehicle ID
  currentLocation     String? // Could be stored as coordinates or address
  fuelLevel           Float?
  kilometresTravelled Float     @default(0)
  tonsRelocated       Float?
  lastUpdated         DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([siteId, equipmentId])
  @@unique([siteId, telematicsId])
}

model User {
  id                              String                     @id @default(cuid())
  siteId                          String?
  site                            Site?                      @relation(fields: [siteId], references: [id])
  email                           String
  firstName                       String                     @db.Citext
  lastName                        String                     @db.Citext
  middleName                      String?
  idNumber                        String?
  contactNumber                   String?
  whatsapp                        String?
  address                         String?
  password                        String?
  passwordSetupToken              String?
  passwordSetupExpires            DateTime?
  authCode                        String?
  authCodeExpires                 DateTime?
  roleId                          String?
  userRole                        UserRole?                  @relation(fields: [roleId], references: [id])
  sessions                        Session[]
  createdAt                       DateTime                   @default(now())
  updatedAt                       DateTime                   @updatedAt
  // assignedJobs                    Job[]                      @relation("JobToDriver") Remove these fields if we don't need them
  requestedJobs                   Job[]                      @relation("Requester")
  jobComments                     JobComment[]
  executions                      Execution[]
  clients                         Client[]
  workOrderComments               WorkOrderComment[]
  status                          UserStatus                 @default(ACTIVE)
  gradedSamples                   SubSample[]                @relation("SubSampleGrader")
  createdBatches                  Batch[]                    @relation("BatchCreator")
  samples                         Sample[]                   @relation("SampleAgent")
  weighbridges                    Weighbridge[]
  onTheGround                     OnTheGround[]
  paymentReports                  PaymentReport[]            @relation("PaymentReportCreator")
  millingReceiptsCreated          MillingReceipt[]           @relation("MillingReceiptCreator")
  createdTransportPricing         TransportPricing[]         @relation("TransportPricingCreator")
  updatedTransportPricing         TransportPricing[]         @relation("TransportPricingUpdater")
  createdGradePricing             GradePricing[]             @relation("GradePricingCreator")
  updatedGradePricing             GradePricing[]             @relation("GradePricingUpdater")
  createdFreeTransport            FreeTransport[]            @relation("FreeTransportCreator")
  updatedFreeTransport            FreeTransport[]            @relation("FreeTransportUpdater")
  createdAreaTransport            AreaTransportCosts[]       @relation("AreaTransportCreator")
  updatedAreaTransport            AreaTransportCosts[]       @relation("AreaTransportUpdater")
  createdSiteExtractionEfficiency SiteExtractionEfficiency[] @relation("SiteExtractionEfficiencyCreator")
  updatedSiteExtractionEfficiency SiteExtractionEfficiency[] @relation("SiteExtractionEfficiencyUpdater")
  createdAreaRoyaltyConfiguration AreaRoyaltyConfiguration[] @relation("AreaRoyaltyConfigurationCreator")
  updatedAreaRoyaltyConfiguration AreaRoyaltyConfiguration[] @relation("AreaRoyaltyConfigurationUpdater")
  supervisorApproval              PaymentReport[]            @relation("SupervisorApproval")
  supervisorRejected              PaymentReport[]            @relation("SupervisorRejection")
  paymentMarked                   PaymentReport[]            @relation("PaymentMarkedBy")
  resampledReports                PaymentReport[]            @relation("ResampledBy")
  stockpilesCreated               Stockpile[]                @relation("StockpileCreatedBy")
  stockpilesAllocated             Stockpile[]                @relation("StockpileAllocatedBy")
  stockpileLoadsAdded             StockpileLoad[]            @relation("StockpileLoadAddedBy")
  stockpileAllocationEvents       StockpileAllocationEvent[] @relation("StockpileAllocationEventAllocatedBy")
  allocationsAllocated             Allocation[]               @relation("AllocationAllocatedBy")
  allocationsFinalized             Allocation[]               @relation("AllocationFinalizedBy")
  allocationStockpilesAdded        AllocationStockpile[]      @relation("AllocationStockpileAddedBy")
  allocationWeighbridgesAdded      AllocationWeighbridge[]    @relation("AllocationWeighbridgeAddedBy")
  allocationStockpileBatchesAdded  AllocationStockpileBatch[] @relation("AllocationStockpileBatchAddedBy")

  @@unique([firstName, lastName])
  @@unique([siteId, email])
  @@unique([siteId, passwordSetupToken])
}

model UserRole {
  id          String   @id @default(cuid())
  siteId      String?
  site        Site?    @relation(fields: [siteId], references: [id])
  name        String   @db.Citext
  description String?
  isSystem    Boolean  @default(false) // System roles cannot be deleted
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  rolePermissions UserPermission[]
  users           User[]

  @@unique([siteId, name])
  @@index([name])
  @@index([isActive])
}

model UserPermission {
  id        String    @id @default(cuid())
  siteId    String?
  site      Site?     @relation(fields: [siteId], references: [id])
  roleId    String // Reference to UserRole instead of enum
  role      UserRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  resource  Resource? // Resource enum for granular control
  action    Action? // Action enum for granular control
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([roleId])
  @@index([resource, action])
}

enum Resource {
  // Systems Management Section
  CONFIGURATION
  USER
  CLIENT
  AUDIT_LOG
  ROLE

  // Mining Management Section
  CLUSTER
  SUB_AREA
  SHAFT
  LOADBAY
  SYNDICATE
  PREFIX_MANAGEMENT

  // Equipment Management Section
  EQUIPMENT
  EQUIPMENT_COMPANY
  WEIGHBRIDGE

  // Ground Operations Section
  ON_THE_GROUND
  ON_THE_GROUND_TEST_RESULT

  // Labs Section
  SAMPLE_RECEIVING
  SAMPLE_MANAGEMENT
  SAMPLE_RECEIVING_LOAD_DETAILS
  SAMPLE_MANAGEMENT_LOAD_DETAILS
  BOTTLE_REGISTRATION
  BOTTLE_ROLLER_MANAGEMENT
  GRADING
  GRADING_REVIEW
  // -------------------- 

  // Payment Management Section
  INTERNAL_EVALUATION
  PAYMENT_REPORT
  PAYMENT_REPORT_GENERATION
  PAYMENT_REPORT_REVIEW
  PAYMENT_REPORT_PAID
  STOCK_VALUE_WEIGHBRIDGE
  STOCK_VALUE_ON_THE_GROUND
  STOCK_VALUE_SAMPLE
  STOCK_VALUE_PAYMENT_REPORT
  STOCK_VALUE_ALLOCATION
  STOCKPILES
  ALLOCATIONS
  ALLOCATION_HISTORY
  BUDGET_REPORT

  // Milling
  SEPARATOR_MILLING
  MILL_PLANNING
  CRUSHING_PLANNING

  // Transport Section
  JOB
  PLAN
}

enum Action {
  CREATE
  READ
  UPDATE
  DELETE
  APPROVE
  EXPORT_PDF
  EDIT_LOAD_CODE
  RECALL
  MAKE_PAYABLE
}

model Equipment {
  id                            String               @id @default(cuid())
  siteId                        String?
  site                          Site?                @relation(fields: [siteId], references: [id])
  description                   String?
  type                          EquipmentType?
  fleetId                       String?              @db.Citext
  make                          String?
  model                         String?
  year                          Int?
  registrationNumber            String?              @db.Citext
  vinSerialId                   String?
  engineCapacity                String?
  fuelConsumption               Float?
  fuelConsumptionUnit           FuelConsumptionUnit?
  loadingCarryingCapacityTonnes Float?
  company                       EquipmentCompany?    @relation(fields: [companyId], references: [id])
  companyId                     String?
  location                      EquipmentLocation?
  locationOtherText             String?
  status                        EquipmentStatus      @default(AVAILABLE)
  telematics                    Telematics?
  maintenanceRecords            Maintenance[]
  createdAt                     DateTime             @default(now())
  updatedAt                     DateTime             @updatedAt
  assignedWorkOrders            WorkOrder[]          @relation("WorkOrderEquipment")
  weighbridges                  Weighbridge[]
  planAssignments               PlanAssignment[]
  millingSite                   MillingSite?         @relation(fields: [millingSiteId], references: [id])
  millingSiteId                 String?
  crushingSite                  CrushingSite?        @relation(fields: [crushingSiteId], references: [id])
  crushingSiteId                String?
  lastAssessedAt                DateTime?
  riskAssessments               RiskAssessment[]
  crushingLoadsAsCrusher       CrushingLoad[]       @relation("CrushingLoadCrusher")

  @@unique([siteId, fleetId])
  @@unique([siteId, registrationNumber])
  @@unique([siteId, vinSerialId])
  @@index([registrationNumber])
  @@index([make, model])
  @@index([crushingSiteId])
}

model MillingSite {
  id        String      @id @default(cuid())
  siteId    String
  name      String      @db.Citext
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  equipment Equipment[]

  @@unique([siteId, name])
  @@index([name])
}

model CrushingSite {
  id        String      @id @default(cuid())
  siteId    String
  name      String      @db.Citext
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  equipment Equipment[]

  @@unique([siteId, name])
  @@index([name])
}

enum EquipmentLocation {
  AMATOLA
  WALDEN
  OTHER
}

enum EquipmentType {
