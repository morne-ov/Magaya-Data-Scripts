model Weighbridge {
  id                       String                    @id @default(cuid())
  siteId                   String?
  site                     Site?                     @relation(fields: [siteId], references: [id])
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  firstWeighTime           DateTime?
  secondWeighTime          DateTime?
  type                     WeighbridgeType
  client                   Client                    @relation(fields: [clientId], references: [id])
  clientId                 String
  operationType            OperationType
  fleet                    Fleet?                    @relation(fields: [fleetId], references: [id])
  fleetId                  String?
  area                     SubArea                   @relation(fields: [areaId], references: [id])
  areaId                   String
  shaftName                String? // When shafts enter the DB change back to relation
  startKm                  Float?
  endKm                    Float?
  mileageKm                Float?
  firstMass                Float? // Tons
  secondMass               Float? // Tons
  tonnage                  Float? // Tons
  agent                    User?                     @relation(fields: [agentId], references: [id])
  agentId                  String?
  productType              ProductType
  primer                   WeighbridgePrimer
  prefix                   Prefix?                   @relation(fields: [prefixId], references: [id])
  prefixId                 String?
  loadCode                 String
  batchNumber              String? // Mandatory for AFTER_MILL_SANDS product type
  isCustomerVehicle        Boolean                   @default(false) // If no mileage is provided, it is a customer vehicle
  status                   WeighbridgeStatus         @default(AWAITING_SECOND_WEIGH)
