  loanPercentage          Float? // User can enter a percentage amount that will be used to calculate the loan amount
  transportCostPercentage Float? // User can enter a percentage amount that will be used to calculate the transport cost
  status                  PaymentReportStatus @default(DRAFT) // If Supervisor rejects the report the status will be set to DRAFT so that the report can be fixed. SupervisorRejectedAt and SupervisorRejectedById will be set.
  client                  Client              @relation(fields: [clientId], references: [id])
  clientId                String
  createdBy               User                @relation(fields: [createdById], references: [id], name: "PaymentReportCreator")
  createdById             String
  /** Once true (set on recall), generated payment PDF uploads include a recall marker in the filename until cleared (never cleared automatically). */
  pdfFileNameIncludeRecall Boolean               @default(false)
  pdfs                     Report[]
  generateReport          Boolean             @default(true)
  supervisorApproval      Boolean             @default(true)
  supervisorApprovedBy    User?               @relation(fields: [supervisorApprovedById], references: [id], name: "SupervisorApproval")
  supervisorApprovedById  String?
  supervisorApprovedAt    DateTime?
  evaluationDate          DateTime?
  supervisorRejectedAt    DateTime?
  supervisorRejectedBy    User?               @relation(fields: [supervisorRejectedById], references: [id], name: "SupervisorRejection")
  supervisorRejectedById  String?
  paymentDate             DateTime?
  paymentMarkedBy         User?               @relation(fields: [paymentMarkedById], references: [id], name: "PaymentMarkedBy")
  paymentMarkedById       String?
  /** UI: mill charge row uses % of per-load gross vs fixed $. */
  millChargeEntryIsPercent      Boolean @default(false)
  /** UI: actual loan deductions row uses % vs $. */
  loanDeductionsEntryIsPercent   Boolean @default(false)
  /** UI: flat-fee transport row uses % vs $. */
  transportChargeEntryIsPercent Boolean @default(false)
  /** UI: parallel array to manual deduction rows (by description order) — each is % vs $. */
  manualDeductionEntryModes     Json?
  /** Not-payable internal batches: grade-only workflow; supervisor approves to APPROVED (not PAID). */
  internalEvaluationOnly        Boolean             @default(false)
  isResampled                   Boolean             @default(false)
  resampledAt                   DateTime?
  resampledById                 String?
