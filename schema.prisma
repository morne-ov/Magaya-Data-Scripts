  millingLoadProgressStatus   MillingLoadProgressStatus?
  createdAt                   DateTime                   @default(now())
  updatedAt                   DateTime                   @updatedAt

  @@index([siteId])
  @@index([crusherId])
}

enum MillingPayment {
  TOAST
  CASH
  UNPAID
}

model MillingReceipt {
  id              String         @id @default(cuid())
  siteId          String?
  site            Site?          @relation(fields: [siteId], references: [id])
  receiptNumber   String
  millingPayment  MillingPayment
  millingCharge   Float
  transportFee    Float
  otherDeductions Float
  totalDeductions Float
  paymentDate     DateTime?
  notes           String?
  createdByUserId String?
  createdBy       User?          @relation("MillingReceiptCreator", fields: [createdByUserId], references: [id])
  millingLoadId   String
  millingLoad     MillingLoad    @relation(fields: [millingLoadId], references: [id], onDelete: Cascade)
  /// Per-load version: v1, v2, v3… (monotonic per milling load).
  version         Int
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([millingLoadId, version])
  @@unique([siteId, receiptNumber])
}

enum MillingLoadProgressStatus {
  NEEDS_INITIAL_ASSESSMENT
  NEEDS_CRUSHING
  IN_CRUSHER
  NEEDS_MILLING
  IN_MILL
  MILLED
  IN_RECOVERY
  RECOVERED
  COMPLETED
  REJECTED_BEFORE_CRUSHING
  REJECTED_BEFORE_MILLING
  REJECTED_DURING_CRUSHING
  REJECTED_DURING_MILLING
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

model RiskAssessment {
  id                     String    @id @default(cuid())
  equipment              Equipment @relation(fields: [equipmentId], references: [id])
  equipmentId            String
  lubrication            Boolean   @default(false)
  beltCondition          Boolean   @default(false)
  waterSupply            Boolean   @default(false)
  slurryPump             Boolean   @default(false)
  emergencyStop          Boolean   @default(false)
  lotoVerification       Boolean   @default(false)
  passed                 Boolean   @default(false)
  userId                 String
  siteId                 String
  riskLevel              RiskLevel
  ppeUsed                String?
  controlMeasuresApplied String?
  hazardsIdentified      String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

/// Per-site sync state; stored in cloud (and optionally edge) for visibility. siteId matches SITE_ID on the edge.
model SiteSyncState {
  id                      String    @id @default(cuid())
  siteId                  String    @unique
  lastSyncedToCloudAt     DateTime?
  lastSyncedFromCloudAt   DateTime?
  syncToCloudInProgress   Boolean   @default(false)
  syncToCloudRunId        String?
  syncToCloudStartedAt    DateTime?
  syncFromCloudInProgress Boolean   @default(false)
  syncFromCloudRunId      String?
  syncFromCloudStartedAt  DateTime?
  lastHeartbeatAt         DateTime?
  updatedAt               DateTime  @updatedAt
}

enum SyncDirection {
  TO_CLOUD
  FROM_CLOUD
}

enum SyncRunStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

enum SyncTrigger {
  SCHEDULED
  MANUAL
  RETRY
}

model SyncRun {
  id         String        @id @default(cuid())
  siteId     String?
  site       Site?         @relation(fields: [siteId], references: [id])
  runId      String
  direction  SyncDirection
  status     SyncRunStatus
  trigger    SyncTrigger?
  startedAt  DateTime
  finishedAt DateTime?
  durationMs Int?

  tablesUpserted    Int?
  totalRowsUpserted Int?
  totalAdded        Int?
  totalUpdated      Int?
  errorCount        Int?

  tablesSuccessful Int?
  tablesTotal      Int?
  rowsSuccessful   Int?
  rowsAttempted    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tableStats SyncRunTableStat[]
  errors     SyncRunError[]

  @@index([siteId, startedAt])
  @@index([runId])
  @@index([direction, startedAt])
}

model SyncRunTableStat {
  id        String  @id @default(cuid())
  syncRun   SyncRun @relation(fields: [syncRunId], references: [id], onDelete: Cascade)
  syncRunId String
  tableName String
  added     Int     @default(0)
  updated   Int     @default(0)
  deleted   Int     @default(0)
  failed    Boolean @default(false)

  @@unique([syncRunId, tableName])
  @@index([tableName])
}

model SyncRunError {
  id        String   @id @default(cuid())
  syncRun   SyncRun  @relation(fields: [syncRunId], references: [id], onDelete: Cascade)
  syncRunId String
  tableName String
  rowId     String?
  message   String
  errorCode String?
  createdAt DateTime @default(now())

  @@index([tableName])
}
